{
  "name": "self-configuration",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "cli": "bun run src/cli.tsx",
    "dev": "bun run server/index.ts & bunx vite --config web/vite.config.ts",
    "dev:server": "bun run server/index.ts",
    "dev:web": "bunx vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "check": "bunx tsc --noEmit"
  },
  "bin": {
    "self-config": "src/cli.tsx"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.5",
    "hono": "^4.12.4",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^0.576.0",
    "oh-my-logo": "^0.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
